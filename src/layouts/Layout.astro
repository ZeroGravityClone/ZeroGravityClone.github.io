---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Datacore Engineering</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 font-sans selection:bg-emerald-500 selection:text-zinc-950">
    <header class="border-b border-zinc-800/80 sticky top-0 bg-zinc-950/80 backdrop-blur z-50">
      <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logotipo de Datacore Engineering -->
        <a href="/" class="font-mono flex items-center gap-1 hover:opacity-90 transition">
          <span class="text-emerald-400 font-bold">[datacore]</span>
          <span class="text-zinc-100 font-light tracking-wider">.eng</span>
        </a>
        <nav class="flex gap-6 text-sm font-medium text-zinc-400">
          <a href="/#proyectos" class="hover:text-zinc-100 transition">Proyectos</a>
          <a href="/#servicios" class="hover:text-zinc-100 transition">Servicios</a>
          <a href="/#about" class="hover:text-zinc-100 transition">Sobre Mí</a>
          <a href="/contact" class="hover:text-zinc-100 transition text-emerald-400">Contacto</a>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-zinc-900 py-8 mt-20 text-center text-xs text-zinc-600">
      <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <p>© {new Date().getFullYear()} Datacore Engineering. Todos los derechos reservados.</p>
        <div class="flex gap-4">
          <a href="https://github.com/ZeroGravityClone" target="_blank" class="hover:text-zinc-400 transition">GitHub</a>
          <a href="/contact" class="hover:text-zinc-400 transition">Contacto</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Estilos específicos para la renderización estricta de Markdown en los Casos de Estudio */
  .prose h3 {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 1.25rem;
    font-weight: 600;
    color: #f4f4f5; /* Zinc 100 */
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    border-left: 2px solid #10b981; /* Emerald 500 */
    padding-left: 0.75rem;
  }
  .prose p {
    color: #a1a1aa; /* Zinc 400 */
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }
  .prose ul {
    list-style-type: square;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: #d4d4d8; /* Zinc 300 */
  }
  .prose li {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }
  .prose code {
    font-family: ui-monospace, monospace;
    background-color: #18181b; /* Zinc 900 */
    color: #34d399; /* Emerald 400 */
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    border: 1px solid #27272a; /* Zinc 800 */
    font-size: 0.85em;
  }
</style>