---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto e Iniciativa de Proyectos">
  <div class="max-w-2xl mx-auto py-12">
    <h1 class="text-3xl font-bold font-mono tracking-tight text-zinc-100 flex items-center gap-2">
      <span class="text-emerald-400">//</span> Iniciar una Consulta
    </h1>
    <p class="text-zinc-400 mt-4 leading-relaxed text-sm">
      ¿Tienes un sistema legacy que requiera migración, un flujo documental que automatizar o necesitas diseñar la arquitectura de un nuevo producto backend? Completa el formulario de abajo y hablemos de los requerimientos de tu negocio.
    </p>

    <!-- Formulario de Contacto Real -->
    <form action="https://api.web3forms.com/submit" method="POST" class="mt-8 space-y-6">
      <!-- Clave de Web3Forms -->
      <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
      
      <!-- Redirección automática tras enviar el formulario -->
      <input type="hidden" name="redirect" value="https://zerogravityclone.github.io/" />

      <div>
        <label for="name" class="block text-xs font-mono uppercase tracking-wider text-zinc-400 mb-2">Nombre Completo</label>
        <input 
          type="text" 
          name="name" 
          id="name" 
          required 
          class="w-full bg-zinc-900 border border-zinc-800 focus:border-emerald-500 rounded px-4 py-2.5 text-sm text-zinc-100 focus:outline-none transition"
          placeholder="Ej. Juan Pérez"
        />
      </div>

      <div>
        <label for="email" class="block text-xs font-mono uppercase tracking-wider text-zinc-400 mb-2">Correo Electrónico</label>
        <input 
          type="email" 
          name="email" 
          id="email" 
          required 
          class="w-full bg-zinc-900 border border-zinc-800 focus:border-emerald-500 rounded px-4 py-2.5 text-sm text-zinc-100 focus:outline-none transition"
          placeholder="juan@empresa.com"
        />
      </div>

      <div>
        <label for="message" class="block text-xs font-mono uppercase tracking-wider text-zinc-400 mb-2">Detalles sobre tu sistema / problema de datos</label>
        <textarea 
          name="message" 
          id="message" 
          rows="5" 
          required 
          class="w-full bg-zinc-900 border border-zinc-800 focus:border-emerald-500 rounded px-4 py-2.5 text-sm text-zinc-100 focus:outline-none transition resize-none"
          placeholder="Describe brevemente la arquitectura actual, el volumen de datos o el cuello de botella técnico que deseas resolver..."
        ></textarea>
      </div>

      <button 
        type="submit" 
        class="w-full bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-bold py-3 px-4 rounded text-sm transition tracking-wider uppercase"
      >
        Enviar Mensaje
      </button>
    </form>

    <!-- Información de contacto alternativa -->
    <div class="mt-16 pt-8 border-t border-zinc-900 text-center">
      <p class="text-xs text-zinc-500 font-mono">DATACORE ENGINEERING</p>
      <div class="flex justify-center gap-6 mt-4 text-sm font-mono">
        <a href="https://github.com/ZeroGravityClone" target="_blank" class="text-zinc-400 hover:text-emerald-400 transition">
          [github]
        </a>
        <a href="mailto:tu-correo@dominio.com" class="text-zinc-400 hover:text-emerald-400 transition">
          [email]
        </a>
      </div>
    </div>
  </div>
</Layout>