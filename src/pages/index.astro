---
import Layout from '../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const projects: CollectionEntry<'projects'>[] = await getCollection('projects');
---

<Layout title="Especialistas en Backend & Arquitectura de Datos">
  <!-- Hero Section -->
  <section class="py-12 md:py-24 border-b border-zinc-900">
    <div class="max-w-3xl">
      <span class="text-xs font-mono text-emerald-400 uppercase tracking-widest bg-emerald-950/40 border border-emerald-800/40 px-3 py-1 rounded-full">
        Consultoría e Ingeniería de Sistemas Activa
      </span>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mt-6 text-zinc-100">
        Diseñamos sistemas transaccionales estables y automatizamos flujos documentales complejos.
      </h1>
      <p class="text-zinc-400 mt-6 text-lg leading-relaxed">
        En **Datacore Engineering** nos enfocamos en el diseño de arquitectura limpia, la gobernanza de datos relacionales y el procesamiento de información no estructurada en memoria. Ayudamos a clínicas, centros de salud y empresas en crecimiento a escalar sus sistemas de datos de forma predecible y segura.
      </p>
      <div class="flex gap-4 mt-8">
        <a href="#proyectos" class="bg-emerald-500 hover:bg-emerald-400 text-zinc-950 px-5 py-2.5 rounded font-semibold text-sm transition">
          Ver Casos de Estudio
        </a>
        <a href="/contact" class="border border-zinc-800 hover:border-zinc-700 bg-zinc-900/50 px-5 py-2.5 rounded font-semibold text-sm text-zinc-300 hover:text-zinc-100 transition">
          Hablemos de tu Proyecto
        </a>
      </div>
    </div>
  </section>

  <!-- Servicios (Enfoque de Negocio y Consultoría) -->
  <section id="servicios" class="py-16 border-b border-zinc-900">
    <h2 class="text-2xl font-semibold text-zinc-100 font-mono tracking-tight flex items-center gap-2">
      <span class="text-emerald-400">//</span> Servicios de Consultoría Técnica
    </h2>
    <div class="grid md:grid-cols-3 gap-6 mt-10">
      <div class="bg-zinc-900/40 border border-zinc-800/60 p-6 rounded-lg hover:border-zinc-700/60 transition">
        <div class="w-8 h-8 rounded bg-emerald-950 flex items-center justify-center text-emerald-400 mb-4 font-mono font-bold text-sm">
          01
        </div>
        <h3 class="text-lg font-semibold text-zinc-200">Sistemas Transaccionales</h3>
        <p class="text-zinc-400 text-sm mt-3 leading-relaxed">
          Diseño y refactorización de bases de datos para sistemas de inventarios, facturación y registros que requieran control estricto de concurrencia, bloqueo de condiciones de carrera y cero pérdida de datos.
        </p>
      </div>

      <div class="bg-zinc-900/40 border border-zinc-800/60 p-6 rounded-lg hover:border-zinc-700/60 transition">
        <div class="w-8 h-8 rounded bg-emerald-950 flex items-center justify-center text-emerald-400 mb-4 font-mono font-bold text-sm">
          02
        </div>
        <h3 class="text-lg font-semibold text-zinc-200">Pipelines de Digitalización</h3>
        <p class="text-zinc-400 text-sm mt-3 leading-relaxed">
          Estructuración de motores de ingesta que procesan, validan y normalizan información de archivos PDF planos o escaneos directamente en memoria hacia bases de datos estructuradas mediante modelos multimodales e IA.
        </p>
      </div>

      <div class="bg-zinc-900/40 border border-zinc-800/60 p-6 rounded-lg hover:border-zinc-700/60 transition">
        <div class="w-8 h-8 rounded bg-emerald-950 flex items-center justify-center text-emerald-400 mb-4 font-mono font-bold text-sm">
          03
        </div>
        <h3 class="text-lg font-semibold text-zinc-200">Refactor de Arquitecturas</h3>
        <p class="text-zinc-400 text-sm mt-3 leading-relaxed">
          Migración estructurada de sistemas monolíticos desordenados o aplicaciones locales hacia APIs web desacopladas bajo principios de modularidad, alta mantenibilidad y trazabilidad histórica mediante registros de auditoría.
        </p>
      </div>
    </div>
  </section>

  <!-- Proyectos Reales (Casos de Estudio) -->
  <section id="proyectos" class="py-16 border-b border-zinc-900">
    <div class="flex justify-between items-end">
      <div>
        <h2 class="text-2xl font-semibold text-zinc-100 font-mono tracking-tight flex items-center gap-2">
          <span class="text-emerald-400">//</span> Casos de Estudio Destacados
        </h2>
        <p class="text-zinc-400 text-sm mt-2">Sistemas de backend e ingesta construidos para resolver cuellos de botella operativos reales en el sector médico.</p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8 mt-10">
      {projects.map((project) => (
        <article class="bg-zinc-900/30 border border-zinc-800/80 p-6 rounded-lg flex flex-col justify-between hover:border-emerald-500/30 hover:bg-zinc-900/50 transition duration-300">
          <div>
            <span class="text-xs font-mono text-emerald-400/80 uppercase tracking-wider">{project.data.role}</span>
            <h3 class="text-xl font-bold text-zinc-100 mt-2 hover:text-emerald-400 transition">
              <a href={`/projects/${project.slug}`}>{project.data.title}</a>
            </h3>
            <p class="text-zinc-400 text-sm mt-3 leading-relaxed line-clamp-3">
              {project.data.description}
            </p>
            <div class="flex flex-wrap gap-2 mt-4">
              {project.data.techStack.map((tech: string) => (
                <span class="text-[11px] font-mono bg-zinc-800 text-zinc-300 px-2.5 py-0.5 rounded border border-zinc-700/50">
                  {tech}
                </span>
              ))}
            </div>
          </div>
          <div class="mt-6 pt-4 border-t border-zinc-800/60 flex items-center justify-between text-xs">
            <a href={`/projects/${project.slug}`} class="text-emerald-400 font-semibold hover:underline">
              Ver Análisis Técnico &rarr;
            </a>
            {project.data.githubBackend && (
              <a href={project.data.githubBackend} target="_blank" class="text-zinc-500 hover:text-zinc-300 flex items-center gap-1 font-mono">
                [codebase]
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Sobre Nosotros / Sobre Mí -->
  <section id="about" class="py-16">
    <div class="grid md:grid-cols-3 gap-8 items-start">
      <div class="md:col-span-1">
        <h2 class="text-2xl font-semibold text-zinc-100 font-mono tracking-tight flex items-center gap-2">
          <span class="text-emerald-400">//</span> Sobre Mí
        </h2>
      </div>
      <div class="md:col-span-2 text-zinc-400 space-y-4 text-base leading-relaxed">
        <p>
          Como Ingeniero de Software detrás de **Datacore Engineering**, mi enfoque metodológico se centra en la construcción de software predecible, con alta integridad referencial y libre de complejidades innecesarias. Cuento con experiencia en el diseño y optimización de bases de datos relacionales, manejo robusto de transacciones concurrentes, y en el desacoplamiento estructurado de sistemas monolíticos legacy.
        </p>
        <p>
          En el área de automatización de datos, diseño arquitecturas capaces de procesar flujos complejos directamente en memoria (como streams binarios de archivos PDF) integrando modelos inteligentes de visión multimodal y validaciones estrictas antes del almacenamiento final, acelerando de forma segura flujos que tradicionalmente requerían la intervención constante de operarios humanos.
        </p>
      </div>
    </div>
  </section>
</Layout>